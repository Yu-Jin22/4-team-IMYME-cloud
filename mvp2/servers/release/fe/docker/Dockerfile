FROM node:20-alpine
RUN npm install -g pnpm
WORKDIR /app

# Copy dependency files
COPY package.json ./
COPY pnpm-lock.yaml* ./
RUN pnpm install

# Copy source code
COPY . .

# Build arguments for Next.js build
ARG NODE_ENV
ARG NEXT_PUBLIC_KAKAO_REST_API_KEY
ARG NEXT_PUBLIC_API_BASE_URL
ARG NEXT_PUBLIC_SERVER_URL
ARG NEXT_PUBLIC_GOOGLE_ANALYTICS
ARG NEXT_PUBLIC_PVP_OPEN
ARG NEXT_PUBLIC_KAKAO_REDIRECT_URI
ARG NEXT_PUBLIC_SECURE
ARG E2E_BASE_URL
ARG PERF_BASE_URL
ARG ALLOW_E2E_LOGIN

# Set environment variables for build
ENV NODE_ENV=${NODE_ENV}
ENV NEXT_PUBLIC_KAKAO_REST_API_KEY=${NEXT_PUBLIC_KAKAO_REST_API_KEY}
ENV NEXT_PUBLIC_API_BASE_URL=${NEXT_PUBLIC_API_BASE_URL}
ENV NEXT_PUBLIC_SERVER_URL=${NEXT_PUBLIC_SERVER_URL}
ENV NEXT_PUBLIC_GOOGLE_ANALYTICS=${NEXT_PUBLIC_GOOGLE_ANALYTICS}
ENV NEXT_PUBLIC_PVP_OPEN=${NEXT_PUBLIC_PVP_OPEN}
ENV NEXT_PUBLIC_KAKAO_REDIRECT_URI=${NEXT_PUBLIC_KAKAO_REDIRECT_URI}
ENV NEXT_PUBLIC_SECURE=${NEXT_PUBLIC_SECURE}
ENV E2E_BASE_URL=${E2E_BASE_URL}
ENV PERF_BASE_URL=${PERF_BASE_URL}
ENV ALLOW_E2E_LOGIN=${ALLOW_E2E_LOGIN}

# Build application
RUN pnpm run build

EXPOSE 3000
CMD ["pnpm", "start"]
